# Database (MariaDB)
DB_HOST=mariadb
DB_PORT=3306
DB_USER=zxpkg
DB_PASSWORD=zxpkg
DB_NAME=zxpkg

# Admin gate for /admin and the manual crawl trigger (single shared token)
ADMIN_TOKEN=change-me

# Where mirrors, artifacts and the compiled index live (mounted volume)
STORE_DIR=/data/store

# Signing key (Rabin-Williams-1024 over SHA-256) — generate with `npm run genkey`
SIGN_KEY_ID=1
SIGN_PRIVATE_KEY=/data/keys/private.json
SIGN_PUBLIC_KEY=/data/keys/public.json

# Re-crawl sweep interval (ms). Default 6h.
POLL_INTERVAL_MS=21600000

# Seed list of repos to index on worker start
SEED_FILE=/app/repos.yaml

# Subdirectory to host under (SEO: zx.in.net/pkg). Empty for local dev / root.
BASE_PATH=
# Public base URL used for canonical tags / sitemap (no trailing slash)
PUBLIC_BASE_URL=http://localhost:3000
